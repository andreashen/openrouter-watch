---
import modelsData from "../../../data/derived/models_latest.json";
import ModelTable from "../components/ModelTable.astro";
import Base from "../layouts/Base.astro";

type ModelRecord = {
  fetched_at: string;
  vendor_name: string;
};

if (!Array.isArray(modelsData) || modelsData.length === 0) {
  throw new Error("data/derived/models_latest.json must contain a non-empty array");
}

for (const [index, model] of modelsData.entries()) {
  if (!model || typeof model !== "object") {
    throw new Error(`models_latest.json row ${index} must be an object`);
  }

  const record = model as Partial<ModelRecord>;
  if (!record.vendor_name) {
    throw new Error(`models_latest.json row ${index} is missing vendor_name`);
  }
}

const models = modelsData as ModelRecord[];
const latestFetchedAt = models
  .map((model) => Date.parse(model.fetched_at))
  .filter((timestamp) => Number.isFinite(timestamp))
  .sort((a, b) => b - a)[0];
const latestFetchedAtLabel = latestFetchedAt
  ? new Intl.DateTimeFormat("en-CA", {
      timeZone: "UTC",
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    })
      .format(new Date(latestFetchedAt))
      .replace(",", "") + " UTC"
  : "Unknown";
const deploymentUrl = "https://andreashen.github.io/openrouter-watch/";
const repositoryUrl = "https://github.com/andreashen/openrouter-watch";
---

<Base
  title="OpenRouter Watch"
  description="Static OpenRouter model table generated from derived model data."
>
  <main class="mx-auto flex max-w-[90rem] flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    <header class="relative overflow-hidden rounded-3xl border border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 p-8 shadow-xl dark:shadow-2xl backdrop-blur-xl">
      <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-sky-400/10 dark:bg-sky-500/20 blur-[128px] pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-indigo-400/10 dark:bg-indigo-500/20 blur-[128px] pointer-events-none"></div>
      
      <div class="relative z-10">
        <div class="flex items-center justify-between">
          <p class="text-sm font-bold uppercase tracking-[0.25em] text-sky-600 dark:text-sky-400">
            OpenRouter Watch
          </p>
          <button id="theme-toggle" class="p-2 rounded-xl bg-slate-200/50 dark:bg-slate-800/50 text-slate-600 dark:text-slate-300 hover:bg-slate-300/50 dark:hover:bg-slate-700/50 transition-colors" aria-label="切换主题">
            <svg id="theme-icon-light" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-icon-dark" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
        <div class="mt-4 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-5xl drop-shadow-sm">
              模型信息表
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
              支持统一搜索、能力复选、数值范围筛选与关键字段排序，为您提供最前沿的 AI 模型全景数据。
            </p>
          </div>
          <div class="flex flex-col items-start gap-3 md:items-end">
            <div class="flex flex-wrap items-center gap-2 md:justify-end">
              <a
                href={deploymentUrl}
                target="_blank"
                rel="noopener noreferrer"
                title={deploymentUrl}
                class="inline-flex items-center gap-2 rounded-xl border border-sky-300/60 bg-sky-100/70 px-3 py-2 text-sm font-semibold text-sky-700 transition-all hover:-translate-y-0.5 hover:border-sky-400/80 hover:bg-sky-200/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:border-sky-600/70 dark:bg-sky-500/15 dark:text-sky-300 dark:hover:border-sky-500 dark:hover:bg-sky-500/25 dark:focus-visible:ring-offset-slate-900"
                aria-label="在线访问部署站点（新标签页打开）"
              >
                在线访问
                <span class="max-w-48 truncate font-mono text-xs sm:max-w-64">{deploymentUrl}</span>
              </a>
              <a
                href={repositoryUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-xl border border-slate-300/70 bg-white/70 px-3 py-2 text-sm font-semibold text-slate-700 transition-all hover:-translate-y-0.5 hover:border-slate-400/80 hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:border-slate-600/70 dark:bg-slate-800/70 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:bg-slate-800 dark:focus-visible:ring-offset-slate-900"
                aria-label="前往 GitHub 仓库，给项目点个 Star（新标签页打开）"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 1.5A10.5 10.5 0 0 0 1.5 12a10.5 10.5 0 0 0 7.18 9.96c.53.1.72-.23.72-.5v-1.95c-2.93.64-3.55-1.24-3.55-1.24-.48-1.2-1.17-1.52-1.17-1.52-.96-.66.08-.65.08-.65 1.06.08 1.62 1.09 1.62 1.09.94 1.62 2.47 1.15 3.07.88.1-.68.37-1.15.67-1.41-2.34-.27-4.8-1.17-4.8-5.2 0-1.15.41-2.09 1.08-2.83-.1-.27-.47-1.38.1-2.88 0 0 .89-.28 2.9 1.08a10.11 10.11 0 0 1 5.28 0c2-1.36 2.88-1.08 2.88-1.08.58 1.5.22 2.61.11 2.88.68.74 1.07 1.68 1.07 2.83 0 4.04-2.47 4.92-4.82 5.18.38.33.73.98.73 1.98v2.95c0 .28.18.6.73.5A10.5 10.5 0 0 0 22.5 12 10.5 10.5 0 0 0 12 1.5Z"></path>
                </svg>
                给项目点个 Star
              </a>
            </div>
            <div class="flex items-center gap-3 rounded-2xl border border-slate-300/50 dark:border-slate-700/50 bg-slate-100/50 dark:bg-slate-800/50 px-5 py-3 text-sm text-slate-700 dark:text-slate-300 backdrop-blur-md shadow-inner">
              <div class="h-2 w-2 rounded-full bg-emerald-500 dark:bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.8)] dark:shadow-[0_0_8px_rgba(52,211,153,0.8)]"></div>
              <span>数据更新时间：<span class="font-mono font-semibold text-slate-900 dark:text-slate-100">{latestFetchedAtLabel}</span></span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <ModelTable models={modelsData} />

    <footer class="pb-8 text-center text-sm text-slate-500">
      数据来源：OpenRouter API。
    </footer>
  </main>

  <script>
    const toggleBtn = document.getElementById('theme-toggle');
    const iconLight = document.getElementById('theme-icon-light');
    const iconDark = document.getElementById('theme-icon-dark');

    function updateIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        if (iconDark) iconDark.classList.remove('hidden');
        if (iconLight) iconLight.classList.add('hidden');
      } else {
        if (iconLight) iconLight.classList.remove('hidden');
        if (iconDark) iconDark.classList.add('hidden');
      }
    }

    updateIcons();

    // Listen to theme changes from other tabs or scripts
    const observer = new MutationObserver(() => {
      updateIcons();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    toggleBtn?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      window.localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons();
    });
  </script>
</Base>
