---
import modelsData from "../../../data/derived/models_latest.json";
import ModelTable from "../components/ModelTable.astro";
import Base from "../layouts/Base.astro";

type ModelRecord = {
  fetched_at: string;
  vendor_name: string;
};

if (!Array.isArray(modelsData) || modelsData.length === 0) {
  throw new Error("data/derived/models_latest.json must contain a non-empty array");
}

for (const [index, model] of modelsData.entries()) {
  if (!model || typeof model !== "object") {
    throw new Error(`models_latest.json row ${index} must be an object`);
  }

  const record = model as Partial<ModelRecord>;
  if (!record.vendor_name) {
    throw new Error(`models_latest.json row ${index} is missing vendor_name`);
  }
}

const models = modelsData as ModelRecord[];
const latestFetchedAt = models
  .map((model) => Date.parse(model.fetched_at))
  .filter((timestamp) => Number.isFinite(timestamp))
  .sort((a, b) => b - a)[0];
const latestFetchedAtLabel = latestFetchedAt
  ? new Intl.DateTimeFormat("en-CA", {
      timeZone: "UTC",
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    })
      .format(new Date(latestFetchedAt))
      .replace(",", "") + " UTC"
  : "Unknown";
---

<Base
  title="OpenRouter Watch"
  description="Static OpenRouter model table generated from derived model data."
>
  <main class="mx-auto flex max-w-[90rem] flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    <header class="relative overflow-hidden rounded-3xl border border-slate-800 bg-slate-900/50 p-8 shadow-2xl backdrop-blur-xl">
      <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-sky-500/20 blur-[128px] pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-indigo-500/20 blur-[128px] pointer-events-none"></div>
      
      <div class="relative z-10">
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-sky-400">
          OpenRouter Watch
        </p>
        <div class="mt-4 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl drop-shadow-sm">
              模型信息表
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-400">
              支持统一搜索、能力复选、数值范围筛选与关键字段排序，为您提供最前沿的 AI 模型全景数据。
            </p>
          </div>
          <div class="flex items-center gap-3 rounded-2xl border border-slate-700/50 bg-slate-800/50 px-5 py-3 text-sm text-slate-300 backdrop-blur-md shadow-inner">
            <div class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.8)]"></div>
            <span>数据更新时间：<span class="font-mono font-semibold text-slate-100">{latestFetchedAtLabel}</span></span>
          </div>
        </div>
      </div>
    </header>

    <ModelTable models={modelsData} />

    <footer class="pb-8 text-center text-sm text-slate-500">
      数据来源：OpenRouter API。前端仅读取 <code class="rounded bg-slate-800 px-1.5 py-0.5 font-mono text-xs text-slate-400">data/derived/models_latest.json</code> 派生产物。
    </footer>
  </main>
</Base>
