---
type Model = {
  model_id: string;
  author: string;
  slug: string;
  vendor_name: string;
  name: string;
  context_length: number | null;
  max_completion_tokens: number | null;
  input_price_usd_per_1m: number | null;
  output_price_usd_per_1m: number | null;
  supports_reasoning: boolean;
  supports_tools: boolean;
  supports_vision: boolean;
  intelligence_index: number | null;
  coding_index: number | null;
  agentic_index: number | null;
  fetched_at: string;
};

type Props = {
  models: Model[];
};

const { models } = Astro.props;
const numberFormatter = new Intl.NumberFormat("en-US");

function truncateToOneDecimal(value: number): string {
  return (Math.trunc(value * 10) / 10).toFixed(1);
}

function formatCompact(value: number | null): string {
  if (value === null) {
    return "—";
  }

  const absValue = Math.abs(value);
  if (absValue >= 1_000_000) {
    return `${truncateToOneDecimal(value / 1_000_000)}M`;
  }
  if (absValue >= 1_000) {
    return `${truncateToOneDecimal(value / 1_000)}K`;
  }
  return numberFormatter.format(value);
}

function formatPrice(value: number | null): string {
  if (value === null) {
    return "—";
  }
  if (value === 0) {
    return "0";
  }
  return value.toFixed(4).replace(/0+$/, "").replace(/\.$/, "");
}

function formatIndex(value: number | null): string {
  return value === null ? "—" : value.toFixed(1);
}

function formatFetchedAt(value: string): string {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) {
    return value;
  }
  const year = date.getUTCFullYear();
  const month = String(date.getUTCMonth() + 1).padStart(2, "0");
  const day = String(date.getUTCDate()).padStart(2, "0");
  const hour = String(date.getUTCHours()).padStart(2, "0");
  const minute = String(date.getUTCMinutes()).padStart(2, "0");
  return `${year}-${month}-${day} ${hour}:${minute} UTC`;
}

const columns = [
  "Model ID",
  "上下文",
  "最大输出",
  "输入价 ($/1M)",
  "输出价 ($/1M)",
  "Reasoning",
  "Tools",
  "Vision",
  "Intelligence",
  "Coding",
  "Agentic",
  "更新时间",
];

const rangeFields = [
  { key: "context_length", label: "上下文" },
  { key: "max_completion_tokens", label: "最大输出" },
  { key: "input_price_usd_per_1m", label: "输入价" },
  { key: "output_price_usd_per_1m", label: "输出价" },
  { key: "intelligence_index", label: "Intelligence" },
  { key: "coding_index", label: "Coding" },
  { key: "agentic_index", label: "Agentic" },
];
---

<section class="rounded-3xl border border-slate-800 bg-slate-900/40 shadow-2xl backdrop-blur-xl overflow-hidden">
  <div class="flex flex-col gap-6 border-b border-slate-800 p-6">
    <div class="grid gap-6 lg:grid-cols-2">
      <div>
        <label for="model-search" class="text-sm font-medium text-slate-300">模型搜索</label>
        <div class="relative mt-2">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-slate-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
            </svg>
          </div>
          <input
            id="model-search"
            type="search"
            placeholder="搜索 model_id / vendor / name / author / slug"
            class="block w-full rounded-xl border border-slate-700 bg-slate-800/50 py-2.5 pl-10 pr-3 text-sm text-slate-200 placeholder:text-slate-500 focus:border-sky-500 focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
          />
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-300">能力筛选（AND）</p>
        <div class="mt-3 flex flex-wrap gap-4 text-sm text-slate-300">
          {['reasoning', 'tools', 'vision'].map((cap) => (
            <label class="group relative flex cursor-pointer items-center gap-2 rounded-lg border border-slate-700 bg-slate-800/30 px-3 py-2 transition-colors hover:bg-slate-800">
              <input id={`cap-${cap}`} type="checkbox" class="peer h-4 w-4 rounded border-slate-600 bg-slate-900 text-sky-500 focus:ring-sky-500/50 focus:ring-offset-slate-900" />
              <span class="capitalize">{cap}</span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <div>
      <p class="text-sm font-medium text-slate-300">关键数值范围（AND）</p>
      <div class="mt-3 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {rangeFields.map((field) => (
          <div class="rounded-xl border border-slate-700/50 bg-slate-800/20 p-3 transition-colors hover:border-slate-600">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-400">{field.label}</p>
            <div class="mt-2 grid grid-cols-2 gap-2">
              <input
                type="number"
                step="any"
                inputmode="decimal"
                placeholder="min"
                data-range-key={field.key}
                data-range-bound="min"
                class="w-full rounded-lg border border-slate-700 bg-slate-900/50 px-2.5 py-1.5 text-sm text-slate-200 placeholder:text-slate-600 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
              />
              <input
                type="number"
                step="any"
                inputmode="decimal"
                placeholder="max"
                data-range-key={field.key}
                data-range-bound="max"
                class="w-full rounded-lg border border-slate-700 bg-slate-900/50 px-2.5 py-1.5 text-sm text-slate-200 placeholder:text-slate-600 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
              />
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="grid gap-4 sm:max-w-2xl sm:grid-cols-2">
      <div>
        <label for="sort-field" class="text-sm font-medium text-slate-300">排序字段</label>
        <select
          id="sort-field"
          class="mt-2 block w-full rounded-xl border border-slate-700 bg-slate-800/50 px-3 py-2.5 text-sm text-slate-200 focus:border-sky-500 focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
        >
          <option value="">不排序</option>
          <option value="context_length">上下文</option>
          <option value="max_completion_tokens">最大输出</option>
          <option value="input_price_usd_per_1m">输入价</option>
          <option value="output_price_usd_per_1m">输出价</option>
          <option value="intelligence_index">Intelligence</option>
          <option value="coding_index">Coding</option>
          <option value="agentic_index">Agentic</option>
          <option value="fetched_at">更新时间</option>
        </select>
      </div>
      <div>
        <label for="sort-direction" class="text-sm font-medium text-slate-300">排序方向</label>
        <select
          id="sort-direction"
          class="mt-2 block w-full rounded-xl border border-slate-700 bg-slate-800/50 px-3 py-2.5 text-sm text-slate-200 focus:border-sky-500 focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
        >
          <option value="none">无</option>
          <option value="asc">升序</option>
          <option value="desc">降序</option>
        </select>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <p id="model-count" class="text-sm font-medium text-sky-400" aria-live="polite">
        共 {models.length} 个模型
      </p>
    </div>
  </div>

  <div class="overflow-x-auto overflow-y-auto max-h-[70vh] custom-scrollbar">
    <table class="min-w-max border-collapse text-left text-sm w-full">
      <thead class="sticky top-0 z-20 bg-slate-900/80 backdrop-blur-md text-xs uppercase tracking-wider text-slate-400 shadow-sm">
        <tr>
          {columns.map((column) => (
            <th class="whitespace-nowrap border-b border-slate-800 px-5 py-4 font-semibold">{column}</th>
          ))}
        </tr>
      </thead>
      <tbody id="model-table-body" class="divide-y divide-slate-800/50">
        {/* Rendered by JS */}
      </tbody>
    </table>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.5);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(51, 65, 85, 0.8);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(71, 85, 105, 0.8);
  }
</style>

<script define:vars={{ models }} is:inline>
  const tableBody = document.querySelector("#model-table-body");
  const count = document.querySelector("#model-count");
  const searchInput = document.querySelector("#model-search");
  const capReasoning = document.querySelector("#cap-reasoning");
  const capTools = document.querySelector("#cap-tools");
  const capVision = document.querySelector("#cap-vision");
  const sortField = document.querySelector("#sort-field");
  const sortDirection = document.querySelector("#sort-direction");
  const rangeInputs = Array.from(document.querySelectorAll("input[data-range-key][data-range-bound]"));
  const totalRows = models.length;
  const numericRangeKeys = [
    "context_length",
    "max_completion_tokens",
    "input_price_usd_per_1m",
    "output_price_usd_per_1m",
    "intelligence_index",
    "coding_index",
    "agentic_index",
  ];

  function truncateToOneDecimal(value) {
    return (Math.trunc(value * 10) / 10).toFixed(1);
  }

  function formatCompact(value) {
    if (value === null) {
      return '<span class="text-slate-600">—</span>';
    }
    const absValue = Math.abs(value);
    let formatted = "";
    if (absValue >= 1_000_000) {
      formatted = `${truncateToOneDecimal(value / 1_000_000)}M`;
    } else if (absValue >= 1_000) {
      formatted = `${truncateToOneDecimal(value / 1_000)}K`;
    } else {
      formatted = new Intl.NumberFormat("en-US").format(value);
    }
    return `<span class="text-slate-300">${formatted}</span>`;
  }

  function formatPrice(value) {
    if (value === null) {
      return '<span class="text-slate-600">—</span>';
    }
    if (value === 0) {
      return '<span class="text-slate-300">0</span>';
    }
    const formatted = value.toFixed(4).replace(/0+$/, "").replace(/\.$/, "");
    return `<span class="text-slate-300">${formatted}</span>`;
  }

  function formatIndex(value) {
    if (value === null) return '<span class="text-slate-600">—</span>';
    const num = value.toFixed(1);
    // Add a subtle color based on value for index
    let colorClass = "text-slate-300";
    if (value >= 80) colorClass = "text-emerald-400 font-medium";
    else if (value >= 50) colorClass = "text-sky-400";
    return `<span class="${colorClass}">${num}</span>`;
  }

  function formatBoolean(value) {
    return value 
      ? `<span class="inline-flex items-center justify-center rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-400 ring-1 ring-inset ring-emerald-500/20">✓</span>` 
      : `<span class="text-slate-600">—</span>`;
  }

  function formatFetchedAt(value) {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return `<span class="text-slate-400">${value}</span>`;
    }
    const year = date.getUTCFullYear();
    const month = String(date.getUTCMonth() + 1).padStart(2, "0");
    const day = String(date.getUTCDate()).padStart(2, "0");
    const hour = String(date.getUTCHours()).padStart(2, "0");
    const minute = String(date.getUTCMinutes()).padStart(2, "0");
    return `<span class="text-slate-400">${year}-${month}-${day} ${hour}:${minute}</span>`;
  }

  function parseRangeValue(input) {
    if (!input) {
      return null;
    }
    const value = input.value.trim();
    if (!value) {
      return null;
    }
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : null;
  }

  function getRangeByKey(key) {
    const minInput = document.querySelector(
      `input[data-range-key="${key}"][data-range-bound="min"]`,
    );
    const maxInput = document.querySelector(
      `input[data-range-key="${key}"][data-range-bound="max"]`,
    );
    return {
      min: parseRangeValue(minInput),
      max: parseRangeValue(maxInput),
    };
  }

  function toSearchText(model) {
    return [
      model.model_id,
      model.vendor_name,
      model.name,
      model.author,
      model.slug,
    ]
      .join(" ")
      .toLowerCase();
  }

  function compareNullableNumber(left, right, direction) {
    if (left === null && right === null) {
      return 0;
    }
    if (left === null) {
      return 1;
    }
    if (right === null) {
      return -1;
    }
    return direction === "asc" ? left - right : right - left;
  }

  function parseFetchedAtValue(value) {
    if (!value) {
      return { valid: false, timestamp: 0, text: "" };
    }
    const timestamp = Date.parse(value);
    if (!Number.isFinite(timestamp)) {
      return { valid: false, timestamp: 0, text: value };
    }
    return { valid: true, timestamp, text: value };
  }

  function compareFetchedAt(left, right, direction) {
    const parsedLeft = parseFetchedAtValue(left);
    const parsedRight = parseFetchedAtValue(right);

    if (!parsedLeft.valid && !parsedRight.valid) {
      return direction === "asc"
        ? parsedLeft.text.localeCompare(parsedRight.text)
        : parsedRight.text.localeCompare(parsedLeft.text);
    }
    if (!parsedLeft.valid) {
      return 1;
    }
    if (!parsedRight.valid) {
      return -1;
    }
    return direction === "asc"
      ? parsedLeft.timestamp - parsedRight.timestamp
      : parsedRight.timestamp - parsedLeft.timestamp;
  }

  function createCellHTML(html, className) {
    const cell = document.createElement("td");
    cell.className = className;
    cell.innerHTML = html;
    return cell;
  }

  function renderRows(rows) {
    if (!tableBody) {
      return;
    }
    tableBody.textContent = "";
    const fragment = document.createDocumentFragment();

    for (const model of rows) {
      const row = document.createElement("tr");
      row.className = "group transition-colors hover:bg-slate-800/50";
      
      // Model ID with a subtle gradient text or just bright color
      row.appendChild(
        createCellHTML(`<span class="font-semibold text-sky-400 group-hover:text-sky-300 transition-colors">${model.model_id}</span>`, "whitespace-nowrap px-5 py-3 font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatCompact(model.context_length), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatCompact(model.max_completion_tokens), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatPrice(model.input_price_usd_per_1m), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatPrice(model.output_price_usd_per_1m), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatBoolean(model.supports_reasoning), "whitespace-nowrap px-5 py-3 text-center"),
      );
      row.appendChild(
        createCellHTML(formatBoolean(model.supports_tools), "whitespace-nowrap px-5 py-3 text-center"),
      );
      row.appendChild(
        createCellHTML(formatBoolean(model.supports_vision), "whitespace-nowrap px-5 py-3 text-center"),
      );
      row.appendChild(
        createCellHTML(formatIndex(model.intelligence_index), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatIndex(model.coding_index), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatIndex(model.agentic_index), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatFetchedAt(model.fetched_at), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      fragment.appendChild(row);
    }
    tableBody.appendChild(fragment);

    if (count) {
      count.innerHTML = `显示 <span class="text-white">${rows.length}</span> / ${totalRows} 个模型`;
    }
  }

  function getNumericValue(model, key) {
    const rawValue = model[key];
    return typeof rawValue === "number" ? rawValue : null;
  }

  function applyFiltersAndSort() {
    const search = searchInput?.value.trim().toLowerCase() ?? "";
    const needsReasoning = capReasoning?.checked ?? false;
    const needsTools = capTools?.checked ?? false;
    const needsVision = capVision?.checked ?? false;
    const directionValue = sortDirection?.value;
    const field = sortField?.value ?? "";
    const direction =
      directionValue === "asc" || directionValue === "desc" ? directionValue : "none";
    const numericRanges = {
      context_length: getRangeByKey("context_length"),
      max_completion_tokens: getRangeByKey("max_completion_tokens"),
      input_price_usd_per_1m: getRangeByKey("input_price_usd_per_1m"),
      output_price_usd_per_1m: getRangeByKey("output_price_usd_per_1m"),
      intelligence_index: getRangeByKey("intelligence_index"),
      coding_index: getRangeByKey("coding_index"),
      agentic_index: getRangeByKey("agentic_index"),
    };

    const filtered = models
      .map((model, index) => ({ model, index }))
      .filter(({ model }) => {
        if (search && !toSearchText(model).includes(search)) {
          return false;
        }
        if (needsReasoning && !model.supports_reasoning) {
          return false;
        }
        if (needsTools && !model.supports_tools) {
          return false;
        }
        if (needsVision && !model.supports_vision) {
          return false;
        }

        for (const key of numericRangeKeys) {
          const range = numericRanges[key];
          const value = getNumericValue(model, key);
          if ((range.min !== null || range.max !== null) && value === null) {
            return false;
          }
          if (range.min !== null && value !== null && value < range.min) {
            return false;
          }
          if (range.max !== null && value !== null && value > range.max) {
            return false;
          }
        }
        return true;
      });

    if (field && direction !== "none") {
      filtered.sort((left, right) => {
        let result = 0;
        if (field === "fetched_at") {
          result = compareFetchedAt(left.model.fetched_at, right.model.fetched_at, direction);
        } else {
          const leftValue = getNumericValue(left.model, field);
          const rightValue = getNumericValue(right.model, field);
          result = compareNullableNumber(leftValue, rightValue, direction);
        }
        if (result !== 0) {
          return result;
        }
        const modelIdCompare = left.model.model_id.localeCompare(right.model.model_id);
        if (modelIdCompare !== 0) {
          return modelIdCompare;
        }
        return left.index - right.index;
      });
    }

    renderRows(filtered.map((entry) => entry.model));
  }

  searchInput?.addEventListener("input", applyFiltersAndSort);
  capReasoning?.addEventListener("change", applyFiltersAndSort);
  capTools?.addEventListener("change", applyFiltersAndSort);
  capVision?.addEventListener("change", applyFiltersAndSort);
  sortField?.addEventListener("change", applyFiltersAndSort);
  sortDirection?.addEventListener("change", applyFiltersAndSort);
  for (const input of rangeInputs) {
    input.addEventListener("input", applyFiltersAndSort);
  }

  applyFiltersAndSort();
</script>
