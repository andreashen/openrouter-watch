---
type Model = {
  model_id: string;
  author: string;
  slug: string;
  vendor_name: string;
  name: string;
  openrouter_model_url?: string | null;
  context_length: number | null;
  max_completion_tokens: number | null;
  input_price_usd_per_1m: number | null;
  output_price_usd_per_1m: number | null;
  supports_reasoning: boolean;
  supports_tools: boolean;
  supports_vision: boolean;
  intelligence_index: number | null;
  coding_index: number | null;
  agentic_index: number | null;
  officially_removed: boolean;
  fetched_at: string;
  updated_at?: string | null;
};

type Props = {
  models: Model[];
};

const { models } = Astro.props;

const columns = [
  "Model ID",
  "上下文",
  "最大输出",
  "输入价 ($/1M)",
  "输出价 ($/1M)",
  "Reasoning",
  "Tools",
  "Vision",
  "Intelligence",
  "Coding",
  "Agentic",
  "更新时间",
];

const rangeFields = [
  { key: "context_length", label: "上下文" },
  { key: "max_completion_tokens", label: "最大输出" },
  { key: "input_price_usd_per_1m", label: "输入价" },
  { key: "output_price_usd_per_1m", label: "输出价" },
  { key: "intelligence_index", label: "Intelligence" },
  { key: "coding_index", label: "Coding" },
  { key: "agentic_index", label: "Agentic" },
];
---

<section class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/40 shadow-2xl backdrop-blur-xl overflow-hidden">
  <div class="flex flex-col gap-6 border-b border-slate-200 dark:border-slate-800 p-6">
    <div class="grid gap-6 lg:grid-cols-2">
      <div>
        <label for="model-search" class="text-sm font-medium text-slate-700 dark:text-slate-300">模型搜索</label>
        <div class="relative mt-2">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
            <svg class="h-5 w-5 text-slate-400 dark:text-slate-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
            </svg>
          </div>
          <input
            id="model-search"
            type="search"
            placeholder="搜索 model_id / vendor / name / author / slug"
            class="block w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800/50 py-2.5 pl-10 pr-3 text-sm text-slate-900 dark:text-slate-200 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:border-sky-500 focus:bg-white dark:focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
          />
        </div>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-700 dark:text-slate-300">能力筛选（AND）</p>
        <div class="mt-3 flex flex-wrap gap-4 text-sm text-slate-700 dark:text-slate-300">
          {['reasoning', 'tools', 'vision'].map((cap) => (
            <label class="group relative flex cursor-pointer items-center gap-2 rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800/30 px-3 py-2 transition-colors hover:bg-slate-200 dark:hover:bg-slate-800">
              <input id={`cap-${cap}`} type="checkbox" class="peer h-4 w-4 rounded border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-sky-500 focus:ring-sky-500/50 focus:ring-offset-white dark:focus:ring-offset-slate-900" />
              <span class="capitalize">{cap}</span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <div>
      <p class="text-sm font-medium text-slate-700 dark:text-slate-300">关键数值范围（AND）</p>
      <div class="mt-3 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {rangeFields.map((field) => (
          <div class="rounded-xl border border-slate-300/50 dark:border-slate-700/50 bg-slate-100/50 dark:bg-slate-800/20 p-3 transition-colors hover:border-slate-400 dark:hover:border-slate-600">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">{field.label}</p>
            <div class="mt-2 grid grid-cols-2 gap-2">
              <input
                type="number"
                step="any"
                inputmode="decimal"
                placeholder="min"
                data-range-key={field.key}
                data-range-bound="min"
                class="w-full rounded-lg border border-slate-300 dark:border-slate-700 bg-white/50 dark:bg-slate-900/50 px-2.5 py-1.5 text-sm text-slate-900 dark:text-slate-200 placeholder:text-slate-400 dark:placeholder:text-slate-600 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
              />
              <input
                type="number"
                step="any"
                inputmode="decimal"
                placeholder="max"
                data-range-key={field.key}
                data-range-bound="max"
                class="w-full rounded-lg border border-slate-300 dark:border-slate-700 bg-white/50 dark:bg-slate-900/50 px-2.5 py-1.5 text-sm text-slate-900 dark:text-slate-200 placeholder:text-slate-400 dark:placeholder:text-slate-600 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
              />
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <div>
        <label for="sort-field" class="text-sm font-medium text-slate-700 dark:text-slate-300">排序字段</label>
        <select
          id="sort-field"
          class="mt-2 block w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800/50 px-3 py-2.5 text-sm text-slate-900 dark:text-slate-200 focus:border-sky-500 focus:bg-white dark:focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors"
        >
          <option value="">不排序</option>
          <option value="context_length">上下文</option>
          <option value="max_completion_tokens">最大输出</option>
          <option value="input_price_usd_per_1m">输入价</option>
          <option value="output_price_usd_per_1m">输出价</option>
          <option value="intelligence_index">Intelligence</option>
          <option value="coding_index">Coding</option>
          <option value="agentic_index">Agentic</option>
          <option value="updated_at">更新时间</option>
        </select>
      </div>
      <div>
        <label for="sort-direction" class="text-sm font-medium text-slate-700 dark:text-slate-300">排序方向</label>
        <select
          id="sort-direction"
          disabled
          class="mt-2 block w-full rounded-xl border border-slate-300 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800/50 px-3 py-2.5 text-sm text-slate-900 dark:text-slate-200 focus:border-sky-500 focus:bg-white dark:focus:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500/50 transition-colors disabled:cursor-not-allowed disabled:opacity-50"
        >
          <option value="desc">降序</option>
          <option value="asc">升序</option>
        </select>
      </div>
      <div>
        <span class="text-sm font-medium text-slate-700 dark:text-slate-300">已下架模型</span>
        <div
          id="removed-filter"
          role="radiogroup"
          aria-label="已下架模型显示方式"
          class="mt-2 inline-flex w-full rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800/30 p-0.5"
        >
          <button
            type="button"
            data-removed-filter="hide"
            aria-pressed="true"
            class="removed-filter-btn flex-1 rounded-md px-2 py-2 text-xs font-medium transition-colors"
          >
            不显示
          </button>
          <button
            type="button"
            data-removed-filter="show"
            aria-pressed="false"
            class="removed-filter-btn flex-1 rounded-md px-2 py-2 text-xs font-medium transition-colors"
          >
            显示
          </button>
          <button
            type="button"
            data-removed-filter="only"
            aria-pressed="false"
            class="removed-filter-btn flex-1 rounded-md px-2 py-2 text-xs font-medium transition-colors"
          >
            只显示
          </button>
        </div>
      </div>
      <div>
        <span class="text-sm font-medium text-slate-700 dark:text-slate-300">模型系列latest</span>
        <div
          id="pointer-filter"
          role="radiogroup"
          aria-label="模型系列 latest 显示方式"
          class="mt-2 inline-flex w-full rounded-lg border border-slate-300 dark:border-slate-700 bg-slate-100/50 dark:bg-slate-800/30 p-0.5"
        >
          <button
            type="button"
            data-pointer-filter="hide"
            aria-pressed="true"
            class="removed-filter-btn flex-1 rounded-md px-2 py-2 text-xs font-medium transition-colors"
          >
            不显示
          </button>
          <button
            type="button"
            data-pointer-filter="show"
            aria-pressed="false"
            class="removed-filter-btn flex-1 rounded-md px-2 py-2 text-xs font-medium transition-colors"
          >
            显示
          </button>
          <button
            type="button"
            data-pointer-filter="only"
            aria-pressed="false"
            class="removed-filter-btn flex-1 rounded-md px-2 py-2 text-xs font-medium transition-colors"
          >
            只显示
          </button>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <p id="model-count" class="text-sm font-medium text-sky-600 dark:text-sky-400" aria-live="polite">
        共 {models.length} 个模型
      </p>
    </div>
  </div>

  <div class="overflow-x-auto overflow-y-auto max-h-[70vh] custom-scrollbar">
    <table id="model-table" class="min-w-max border-collapse text-left text-sm w-full">
      <thead class="sticky top-0 z-20 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md text-xs uppercase tracking-wider text-slate-500 dark:text-slate-400 shadow-sm">
        <tr>
          {columns.map((column, index) => (
            index === 0 ? (
              <th
                id="model-id-col-header"
                data-col="model-id"
                class="relative whitespace-nowrap border-b border-slate-200 dark:border-slate-800 px-5 py-4 font-semibold"
              >
                <span>{column}</span>
                <span
                  id="model-id-col-resizer"
                  role="separator"
                  aria-orientation="vertical"
                  aria-label="调整 Model ID 列宽"
                  tabindex="0"
                  class="absolute right-0 top-0 z-30 h-full w-1.5 cursor-col-resize touch-none select-none bg-transparent hover:bg-sky-500/40 focus-visible:bg-sky-500/50 focus-visible:outline-none"
                ></span>
              </th>
            ) : (
              <th class="whitespace-nowrap border-b border-slate-200 dark:border-slate-800 px-5 py-4 font-semibold">{column}</th>
            )
          ))}
        </tr>
      </thead>
      <tbody id="model-table-body" class="divide-y divide-slate-100 dark:divide-slate-800/50">
        {/* Rendered by JS */}
      </tbody>
    </table>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.5);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(51, 65, 85, 0.8);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(71, 85, 105, 0.8);
  }

  .removed-filter-btn[aria-pressed="true"] {
    background: rgb(14 165 233 / 0.15);
    color: rgb(2 132 199);
    box-shadow: inset 0 0 0 1px rgb(14 165 233 / 0.35);
  }

  .removed-filter-btn[aria-pressed="false"] {
    color: rgb(71 85 105);
  }

  :global(.dark) .removed-filter-btn[aria-pressed="true"] {
    background: rgb(14 165 233 / 0.2);
    color: rgb(125 211 252);
    box-shadow: inset 0 0 0 1px rgb(14 165 233 / 0.4);
  }

  :global(.dark) .removed-filter-btn[aria-pressed="false"] {
    color: rgb(148 163 184);
  }

  #model-id-col-resizer::after {
    content: "";
    position: absolute;
    inset: 0 -3px;
  }

  body.model-id-col-resizing {
    cursor: col-resize;
    user-select: none;
  }
</style>

<script define:vars={{ models }} is:inline>
  const tableBody = document.querySelector("#model-table-body");
  const modelTable = document.querySelector("#model-table");
  const modelIdColHeader = document.querySelector("#model-id-col-header");
  const modelIdColResizer = document.querySelector("#model-id-col-resizer");
  const count = document.querySelector("#model-count");
  const searchInput = document.querySelector("#model-search");
  const capReasoning = document.querySelector("#cap-reasoning");
  const capTools = document.querySelector("#cap-tools");
  const capVision = document.querySelector("#cap-vision");
  const removedFilterButtons = Array.from(document.querySelectorAll("[data-removed-filter]"));
  const pointerFilterButtons = Array.from(document.querySelectorAll("[data-pointer-filter]"));
  const sortField = document.querySelector("#sort-field");
  const sortDirection = document.querySelector("#sort-direction");
  const rangeInputs = Array.from(document.querySelectorAll("input[data-range-key][data-range-bound]"));
  const totalRows = models.length;
  const MODEL_ID_COL_WIDTH_KEY = "openrouter-watch.model-id-column-width";
  const MODEL_ID_COL_MIN_WIDTH = 140;
  const MODEL_ID_COL_MAX_WIDTH = 480;
  let removedFilterMode = "hide";
  let pointerFilterMode = "hide";
  let modelIdColWidth = null;
  const numericRangeKeys = [
    "context_length",
    "max_completion_tokens",
    "input_price_usd_per_1m",
    "output_price_usd_per_1m",
    "intelligence_index",
    "coding_index",
    "agentic_index",
  ];

  function clampModelIdColWidth(width) {
    return Math.min(MODEL_ID_COL_MAX_WIDTH, Math.max(MODEL_ID_COL_MIN_WIDTH, width));
  }

  function readStoredModelIdColWidth() {
    try {
      const raw = window.localStorage.getItem(MODEL_ID_COL_WIDTH_KEY);
      if (!raw) {
        return null;
      }
      const parsed = Number(raw);
      return Number.isFinite(parsed) ? clampModelIdColWidth(parsed) : null;
    } catch {
      return null;
    }
  }

  function persistModelIdColWidth(width) {
    try {
      if (width === null) {
        window.localStorage.removeItem(MODEL_ID_COL_WIDTH_KEY);
        return;
      }
      window.localStorage.setItem(MODEL_ID_COL_WIDTH_KEY, String(width));
    } catch {
      // Ignore storage failures.
    }
  }

  function applyModelIdColWidth(width) {
    modelIdColWidth = width;
    const widthStyle = width === null ? "" : `${width}px`;
    if (modelIdColHeader) {
      modelIdColHeader.style.width = widthStyle;
      modelIdColHeader.style.maxWidth = widthStyle;
      modelIdColHeader.style.minWidth = widthStyle;
    }
    if (modelTable) {
      modelTable.style.tableLayout = width === null ? "" : "fixed";
    }
    for (const cell of document.querySelectorAll('td[data-col="model-id"]')) {
      cell.style.width = widthStyle;
      cell.style.maxWidth = widthStyle;
      cell.style.minWidth = widthStyle;
    }
  }

  function initModelIdColResize() {
    modelIdColWidth = readStoredModelIdColWidth();
    applyModelIdColWidth(modelIdColWidth);

    if (!modelIdColResizer || !modelIdColHeader) {
      return;
    }

    let startX = 0;
    let startWidth = 0;

    const stopResize = () => {
      document.body.classList.remove("model-id-col-resizing");
      window.removeEventListener("mousemove", onMouseMove);
      window.removeEventListener("mouseup", stopResize);
      if (modelIdColWidth !== null) {
        persistModelIdColWidth(modelIdColWidth);
      }
    };

    const onMouseMove = (event) => {
      const delta = event.clientX - startX;
      const nextWidth = clampModelIdColWidth(startWidth + delta);
      applyModelIdColWidth(nextWidth);
    };

    const startResize = (clientX) => {
      const measuredWidth = modelIdColHeader.getBoundingClientRect().width;
      startX = clientX;
      startWidth = modelIdColWidth ?? measuredWidth;
      document.body.classList.add("model-id-col-resizing");
      window.addEventListener("mousemove", onMouseMove);
      window.addEventListener("mouseup", stopResize);
    };

    modelIdColResizer.addEventListener("mousedown", (event) => {
      event.preventDefault();
      startResize(event.clientX);
    });

    modelIdColResizer.addEventListener("keydown", (event) => {
      if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") {
        return;
      }
      event.preventDefault();
      const measuredWidth = modelIdColHeader.getBoundingClientRect().width;
      const currentWidth = modelIdColWidth ?? measuredWidth;
      const delta = event.key === "ArrowLeft" ? -8 : 8;
      const nextWidth = clampModelIdColWidth(currentWidth + delta);
      applyModelIdColWidth(nextWidth);
      persistModelIdColWidth(nextWidth);
    });
  }

  function setRemovedFilterMode(mode) {
    removedFilterMode = mode;
    for (const button of removedFilterButtons) {
      const isActive = button.dataset.removedFilter === mode;
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
    }
  }

  function setPointerFilterMode(mode) {
    pointerFilterMode = mode;
    for (const button of pointerFilterButtons) {
      const isActive = button.dataset.pointerFilter === mode;
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
    }
  }

  function isPointerModel(model) {
    const modelId = model.model_id;
    if (modelId.startsWith("~")) {
      return true;
    }
    const slugPart = modelId.split("/", 2)[1] ?? "";
    return slugPart.includes("-latest");
  }

  function updateSortDirectionState({ resetDirection = false } = {}) {
    const field = sortField?.value ?? "";
    const hasField = Boolean(field);
    if (!sortDirection) {
      return;
    }
    sortDirection.disabled = !hasField;
    if (hasField && resetDirection) {
      sortDirection.value = "desc";
    }
  }

  function matchesRemovedFilter(model) {
    if (removedFilterMode === "show") {
      return true;
    }
    if (removedFilterMode === "only") {
      return model.officially_removed;
    }
    return !model.officially_removed;
  }

  function matchesPointerFilter(model) {
    const isPointer = isPointerModel(model);
    if (!isPointer) {
      return pointerFilterMode !== "only";
    }
    if (pointerFilterMode === "hide") {
      return false;
    }
    if (pointerFilterMode === "only") {
      return true;
    }
    return true;
  }

  function truncateToOneDecimal(value) {
    return (Math.trunc(value * 10) / 10).toFixed(1);
  }

  function formatCompact(value) {
    if (value === null) {
      return '<span class="text-slate-400 dark:text-slate-600">—</span>';
    }
    const absValue = Math.abs(value);
    let formatted = "";
    if (absValue >= 1_000_000) {
      formatted = `${truncateToOneDecimal(value / 1_000_000)}M`;
    } else if (absValue >= 1_000) {
      formatted = `${truncateToOneDecimal(value / 1_000)}K`;
    } else {
      formatted = new Intl.NumberFormat("en-US").format(value);
    }
    return `<span class="text-slate-700 dark:text-slate-300">${formatted}</span>`;
  }

  function formatPrice(value) {
    if (value === null) {
      return '<span class="text-slate-400 dark:text-slate-600">—</span>';
    }
    if (value === 0) {
      return '<span class="text-slate-700 dark:text-slate-300">0</span>';
    }
    const formatted = value.toFixed(4).replace(/0+$/, "").replace(/\.$/, "");
    return `<span class="text-slate-700 dark:text-slate-300">${formatted}</span>`;
  }

  function formatIndex(value) {
    if (value === null) return '<span class="text-slate-400 dark:text-slate-600">—</span>';
    const num = value.toFixed(1);
    // Add a subtle color based on value for index
    let colorClass = "text-slate-700 dark:text-slate-300";
    if (value >= 80) colorClass = "text-emerald-600 dark:text-emerald-400 font-medium";
    else if (value >= 50) colorClass = "text-sky-600 dark:text-sky-400";
    return `<span class="${colorClass}">${num}</span>`;
  }

  function formatBoolean(value) {
    return value 
      ? `<span class="inline-flex items-center justify-center rounded-full bg-emerald-100 dark:bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-600 dark:text-emerald-400 ring-1 ring-inset ring-emerald-500/20">✓</span>` 
      : `<span class="text-slate-400 dark:text-slate-600">—</span>`;
  }

  function formatTimestamp(value) {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return `<span class="text-slate-500 dark:text-slate-400">${value}</span>`;
    }
    const year = date.getUTCFullYear();
    const month = String(date.getUTCMonth() + 1).padStart(2, "0");
    const day = String(date.getUTCDate()).padStart(2, "0");
    const hour = String(date.getUTCHours()).padStart(2, "0");
    const minute = String(date.getUTCMinutes()).padStart(2, "0");
    return `<span class="text-slate-500 dark:text-slate-400">${year}-${month}-${day} ${hour}:${minute}</span>`;
  }

  function getModelUrl(model) {
    return model.openrouter_model_url || `https://openrouter.ai/${model.model_id}`;
  }

  function getUpdatedAtValue(model) {
    return model.updated_at || model.fetched_at || "";
  }

  function createModelIdHTML(model) {
    const removedBadge = model.officially_removed
      ? '<span class="rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-semibold text-amber-700 ring-1 ring-inset ring-amber-200 dark:bg-amber-500/15 dark:text-amber-300 dark:ring-amber-500/30">已下架</span>'
      : "";
    const url = getModelUrl(model);
    return `
      <a
        href="${url}"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500/50"
      >
        <span class="font-semibold text-sky-600 group-hover:text-sky-700 dark:text-sky-400 dark:group-hover:text-sky-300 transition-colors">${model.model_id}</span>
        ${removedBadge}
      </a>
    `;
  }

  function parseRangeValue(input) {
    if (!input) {
      return null;
    }
    const value = input.value.trim();
    if (!value) {
      return null;
    }
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : null;
  }

  function getRangeByKey(key) {
    const minInput = document.querySelector(
      `input[data-range-key="${key}"][data-range-bound="min"]`,
    );
    const maxInput = document.querySelector(
      `input[data-range-key="${key}"][data-range-bound="max"]`,
    );
    return {
      min: parseRangeValue(minInput),
      max: parseRangeValue(maxInput),
    };
  }

  function toSearchText(model) {
    return [
      model.model_id,
      model.vendor_name,
      model.name,
      model.author,
      model.slug,
    ]
      .join(" ")
      .toLowerCase();
  }

  function compareNullableNumber(left, right, direction) {
    if (left === null && right === null) {
      return 0;
    }
    if (left === null) {
      return 1;
    }
    if (right === null) {
      return -1;
    }
    return direction === "asc" ? left - right : right - left;
  }

  function parseFetchedAtValue(value) {
    if (!value) {
      return { valid: false, timestamp: 0, text: "" };
    }
    const timestamp = Date.parse(value);
    if (!Number.isFinite(timestamp)) {
      return { valid: false, timestamp: 0, text: value };
    }
    return { valid: true, timestamp, text: value };
  }

  function compareFetchedAt(left, right, direction) {
    const parsedLeft = parseFetchedAtValue(left);
    const parsedRight = parseFetchedAtValue(right);

    if (!parsedLeft.valid && !parsedRight.valid) {
      return direction === "asc"
        ? parsedLeft.text.localeCompare(parsedRight.text)
        : parsedRight.text.localeCompare(parsedLeft.text);
    }
    if (!parsedLeft.valid) {
      return 1;
    }
    if (!parsedRight.valid) {
      return -1;
    }
    return direction === "asc"
      ? parsedLeft.timestamp - parsedRight.timestamp
      : parsedRight.timestamp - parsedLeft.timestamp;
  }

  function createCellHTML(html, className, dataset = {}) {
    const cell = document.createElement("td");
    cell.className = className;
    for (const [key, value] of Object.entries(dataset)) {
      cell.dataset[key] = value;
    }
    cell.innerHTML = html;
    return cell;
  }

  function renderRows(rows) {
    if (!tableBody) {
      return;
    }
    tableBody.textContent = "";
    const fragment = document.createDocumentFragment();

    for (const model of rows) {
      const row = document.createElement("tr");
      row.className = `group transition-colors hover:bg-slate-50 dark:hover:bg-slate-800/50${model.officially_removed ? " opacity-70" : ""}`;
      
      row.appendChild(
        createCellHTML(createModelIdHTML(model), "whitespace-nowrap px-5 py-3 font-mono text-xs", { col: "model-id" }),
      );
      row.appendChild(
        createCellHTML(formatCompact(model.context_length), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatCompact(model.max_completion_tokens), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatPrice(model.input_price_usd_per_1m), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatPrice(model.output_price_usd_per_1m), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatBoolean(model.supports_reasoning), "whitespace-nowrap px-5 py-3 text-center"),
      );
      row.appendChild(
        createCellHTML(formatBoolean(model.supports_tools), "whitespace-nowrap px-5 py-3 text-center"),
      );
      row.appendChild(
        createCellHTML(formatBoolean(model.supports_vision), "whitespace-nowrap px-5 py-3 text-center"),
      );
      row.appendChild(
        createCellHTML(formatIndex(model.intelligence_index), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatIndex(model.coding_index), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatIndex(model.agentic_index), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      row.appendChild(
        createCellHTML(formatTimestamp(getUpdatedAtValue(model)), "whitespace-nowrap px-5 py-3 tabular-nums font-mono text-xs"),
      );
      fragment.appendChild(row);
    }
    tableBody.appendChild(fragment);
    applyModelIdColWidth(modelIdColWidth);

    if (count) {
      count.innerHTML = `显示 <span class="text-slate-900 dark:text-white">${rows.length}</span> / ${totalRows} 个模型`;
    }
  }

  function getNumericValue(model, key) {
    const rawValue = model[key];
    return typeof rawValue === "number" ? rawValue : null;
  }

  function applyFiltersAndSort() {
    const search = searchInput?.value.trim().toLowerCase() ?? "";
    const needsReasoning = capReasoning?.checked ?? false;
    const needsTools = capTools?.checked ?? false;
    const needsVision = capVision?.checked ?? false;
    const directionValue = sortDirection?.value;
    const field = sortField?.value ?? "";
    const direction = directionValue === "asc" ? "asc" : "desc";
    const numericRanges = {
      context_length: getRangeByKey("context_length"),
      max_completion_tokens: getRangeByKey("max_completion_tokens"),
      input_price_usd_per_1m: getRangeByKey("input_price_usd_per_1m"),
      output_price_usd_per_1m: getRangeByKey("output_price_usd_per_1m"),
      intelligence_index: getRangeByKey("intelligence_index"),
      coding_index: getRangeByKey("coding_index"),
      agentic_index: getRangeByKey("agentic_index"),
    };

    const filtered = models
      .map((model, index) => ({ model, index }))
      .filter(({ model }) => {
        if (search && !toSearchText(model).includes(search)) {
          return false;
        }
        if (needsReasoning && !model.supports_reasoning) {
          return false;
        }
        if (needsTools && !model.supports_tools) {
          return false;
        }
        if (needsVision && !model.supports_vision) {
          return false;
        }
        if (!matchesRemovedFilter(model)) {
          return false;
        }
        if (!matchesPointerFilter(model)) {
          return false;
        }

        for (const key of numericRangeKeys) {
          const range = numericRanges[key];
          const value = getNumericValue(model, key);
          if ((range.min !== null || range.max !== null) && value === null) {
            return false;
          }
          if (range.min !== null && value !== null && value < range.min) {
            return false;
          }
          if (range.max !== null && value !== null && value > range.max) {
            return false;
          }
        }
        return true;
      });

    if (field) {
      filtered.sort((left, right) => {
        let result = 0;
        if (field === "updated_at") {
          result = compareFetchedAt(getUpdatedAtValue(left.model), getUpdatedAtValue(right.model), direction);
        } else {
          const leftValue = getNumericValue(left.model, field);
          const rightValue = getNumericValue(right.model, field);
          result = compareNullableNumber(leftValue, rightValue, direction);
        }
        if (result !== 0) {
          return result;
        }
        const modelIdCompare = left.model.model_id.localeCompare(right.model.model_id);
        if (modelIdCompare !== 0) {
          return modelIdCompare;
        }
        return left.index - right.index;
      });
    }

    renderRows(filtered.map((entry) => entry.model));
  }

  searchInput?.addEventListener("input", applyFiltersAndSort);
  capReasoning?.addEventListener("change", applyFiltersAndSort);
  capTools?.addEventListener("change", applyFiltersAndSort);
  capVision?.addEventListener("change", applyFiltersAndSort);
  for (const button of removedFilterButtons) {
    button.addEventListener("click", () => {
      const mode = button.dataset.removedFilter;
      if (!mode || mode === removedFilterMode) {
        return;
      }
      setRemovedFilterMode(mode);
      applyFiltersAndSort();
    });
  }
  for (const button of pointerFilterButtons) {
    button.addEventListener("click", () => {
      const mode = button.dataset.pointerFilter;
      if (!mode || mode === pointerFilterMode) {
        return;
      }
      setPointerFilterMode(mode);
      applyFiltersAndSort();
    });
  }
  sortField?.addEventListener("change", () => {
    updateSortDirectionState({ resetDirection: true });
    applyFiltersAndSort();
  });
  sortDirection?.addEventListener("change", applyFiltersAndSort);
  for (const input of rangeInputs) {
    input.addEventListener("input", applyFiltersAndSort);
  }

  initModelIdColResize();
  updateSortDirectionState();
  applyFiltersAndSort();
</script>
